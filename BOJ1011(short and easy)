#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

int main()
{
	int t, x, y;
	scanf("%d", &t);
	for (int i = 0; i < t; i++) {
		scanf("%d %d", &x, &y);
		int distance = y - x;
		int index = 1;
		long int max = 1;
		while (max < distance) {
			max += index / 2 + 1;
			index++;
		}
		printf("%d\n", index);

	}
	return 0;
}
